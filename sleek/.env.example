# Database (inside Docker network, services use container names)
DATABASE_URL=postgresql+asyncpg://sleek:sleek_dev@db:5432/sleek
POSTGRES_USER=sleek
POSTGRES_PASSWORD=sleek_dev
POSTGRES_DB=sleek

# Redis
REDIS_URL=redis://:sleek_redis_dev@redis:6379/0
REDIS_PASSWORD=sleek_redis_dev

# Celery
CELERY_BROKER_URL=redis://:sleek_redis_dev@redis:6379/0
CELERY_RESULT_BACKEND=redis://:sleek_redis_dev@redis:6379/1

# JWT
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Apify
APIFY_API_TOKEN=

# AI
ANTHROPIC_API_KEY=

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Domain (production only)
DOMAIN=localhost
